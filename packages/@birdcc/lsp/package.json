{
  "name": "@birdcc/lsp",
  "version": "0.0.1-alpha.3",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "author": {
    "name": "BIRD Chinese Community",
    "email": "npm-dev@birdcc.link",
    "url": "https://github.com/bird-chinese-community/"
  },
  "description": "Language Server Protocol implementation for BIRD2 configuration files.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@birdcc/core": "workspace:*",
    "@birdcc/linter": "workspace:*",
    "yaml": "^2.8.2",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "@birdcc/parser": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-hover-yaml.mjs && pnpm run hover:coverage:check",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint --deny-warnings src test",
    "test": "vitest run",
    "hover:coverage": "node scripts/report-hover-coverage.mjs",
    "hover:coverage:check": "node scripts/report-hover-coverage.mjs --check",
    "format": "oxfmt .",
    "coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text-summary --coverage.reporter=json-summary"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bird-chinese-community/BIRD-LSP",
    "directory": "packages/@birdcc/lsp"
  },
  "homepage": "https://github.com/bird-chinese-community/BIRD-LSP/blob/main/packages/%40birdcc/lsp/README.md",
  "bugs": {
    "url": "https://github.com/bird-chinese-community/BIRD-LSP/issues"
  }
}
