{
  "name": "@birdcc/formatter",
  "version": "0.0.1-alpha.5",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "author": {
    "name": "BIRD Chinese Community",
    "email": "npm-dev@birdcc.link",
    "url": "https://github.com/bird-chinese-community/"
  },
  "description": "Formatter for BIRD2 configuration files with dprint and builtin engines.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@birdcc/dprint-plugin-bird": "workspace:*",
    "@birdcc/parser": "workspace:*",
    "@dprint/formatter": "^0.5.1"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint --deny-warnings src test",
    "test": "vitest run",
    "test:quick": "vitest run --exclude '**/realworld*'",
    "format": "oxfmt .",
    "coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text-summary --coverage.reporter=json-summary"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bird-chinese-community/BIRD-LSP",
    "directory": "packages/@birdcc/formatter"
  },
  "homepage": "https://github.com/bird-chinese-community/BIRD-LSP/blob/main/packages/%40birdcc/formatter/README.md",
  "bugs": {
    "url": "https://github.com/bird-chinese-community/BIRD-LSP/issues"
  }
}
