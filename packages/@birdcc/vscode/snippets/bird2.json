{
  "bird-dir-router-id": {
    "prefix": ["bird-dir-router-id", "bird-global-router-id", "router-id", "router id"],
    "description": "[Dir] Set router identifier (Basic)",
    "body": ["router id ${1:192.168.1.1};", "$0"]
  },
  "bird-dir-include": {
    "prefix": ["bird-dir-include", "bird-global-include", "include"],
    "description": "[Dir] Include external configuration file (Basic)",
    "body": ["include \"${1:path/to/file.conf}\";", "$0"]
  },
  "bird-var-define": {
    "prefix": ["bird-var-define", "bird-global-define", "define", "constant"],
    "description": "[Var] Define constant value (Basic)",
    "body": ["define ${1:CONST_NAME} = ${2:value};", "$0"]
  },
  "bird-dir-log": {
    "prefix": ["bird-dir-log", "bird-global-log", "log", "logging"],
    "description": "[Dir] Configure logging output (Basic)",
    "body": [
      "log ${1|syslog,stderr,stdout,\"/var/log/bird.log\"|} ${2|all,debug,trace,info,warning,error,fatal|};",
      "$0"
    ]
  },
  "bird-dir-timebase": {
    "prefix": ["bird-dir-timebase", "bird-global-timebase", "timebase", "time base"],
    "description": "[Dir] Set timebase for protocol timing (Basic)",
    "body": ["timebase real ${1|enabled,disabled|};", "$0"]
  },
  "bird-dir-graceful-restart": {
    "prefix": [
      "bird-dir-graceful-restart",
      "bird-global-graceful-restart",
      "graceful",
      "graceful restart"
    ],
    "description": "[Dir] Configure graceful restart capability (Full)",
    "body": [
      "graceful restart ${1|yes,no|};",
      "graceful restart wait ${2:5};",
      "$0"
    ]
  },
  "bird-dir-watchdog": {
    "prefix": ["bird-dir-watchdog", "bird-global-watchdog", "watchdog"],
    "description": "[Dir] Configure watchdog timeout warnings (Basic)",
    "body": ["watchdog warning ${1:5};", "$0"]
  },
  "bird-proto-tmpl": {
    "prefix": ["bird-proto-tmpl", "template", "protocol template"],
    "description": "[Protocol] Protocol template definition (Basic)",
    "body": [
      "template ${1:bgp} ${2:tmpl_name} {",
      "  ${3:local as 65001;}",
      "  ${4:neighbor 192.168.1.1 as 65002;}",
      "  $0",
      "}"
    ]
  },
  "bird-proto-from-tmpl": {
    "prefix": ["bird-proto-from-tmpl", "from-template", "protocol from"],
    "description": "[Protocol] Protocol from template (Basic)",
    "body": [
      "protocol ${1:bgp} ${2:peer_name} from ${3:tmpl_name} {",
      "  neighbor ${4:192.168.1.2} as ${5:65002};",
      "  $0",
      "}"
    ]
  },
  "bird-proto-device": {
    "prefix": ["bird-proto-device", "device", "protocol device"],
    "description": "[Protocol] Device scan protocol (Basic)",
    "body": ["protocol device {", "  scan time ${1:10};", "  $0", "}"]
  },
  "bird-proto-kernel": {
    "prefix": ["bird-proto-kernel", "kernel", "protocol kernel"],
    "description": "[Protocol] Kernel routing table synchronization (Basic)",
    "body": [
      "protocol kernel {",
      "  ipv${1|4,6|} {",
      "    import ${2|all,none,filter|};",
      "    export ${3|all,none,filter|};",
      "  };",
      "  $0",
      "}"
    ]
  },
  "bird-proto-static": {
    "prefix": ["bird-proto-static", "static", "protocol static"],
    "description": "[Protocol] Static routes configuration (Basic)",
    "body": [
      "protocol static {",
      "  ipv${1|4,6|};",
      "  ",
      "  route ${2:10.0.0.0/8} via ${3:192.168.1.1};",
      "  route ${4:192.168.0.0/16} blackhole;",
      "  $0",
      "}"
    ]
  },
  "bird-proto-direct": {
    "prefix": ["bird-proto-direct", "direct", "protocol direct"],
    "description": "[Protocol] Direct routes protocol (Basic)",
    "body": [
      "protocol direct {",
      "  ipv${1|4,6|};",
      "  ",
      "  interface \"${2:*}\";",
      "  $0",
      "}"
    ]
  },
  "bird-proto-pipe": {
    "prefix": ["bird-proto-pipe", "pipe", "protocol pipe"],
    "description": "[Protocol] Pipe protocol between routing tables (Basic)",
    "body": [
      "protocol pipe ${1:pipe_name} {",
      "  table ${2:master};",
      "  peer table ${3:master2};",
      "  ",
      "  import ${4|all,none,filter|};",
      "  export ${5|all,none,filter|};",
      "  $0",
      "}"
    ]
  },
  "bird-proto-bgp-basic": {
    "prefix": ["bird-proto-bgp", "bgp", "bgp basic"],
    "description": "[Protocol] BGP protocol configuration (Basic)",
    "body": [
      "protocol bgp ${1:peer_name} {",
      "  local as ${2:65001};",
      "  neighbor ${3:192.168.1.1} as ${4:65002};",
      "  ",
      "  ipv4 {",
      "    import ${5:all};",
      "    export ${6:all};",
      "  };",
      "  $0",
      "}"
    ]
  },
  "bird-proto-bgp-full": {
    "prefix": ["bird-proto-bgp-full", "bgp-full"],
    "description": "[Protocol] BGP protocol configuration (Full)",
    "body": [
      "protocol bgp ${1:peer_name} {",
      "  description \"${2:Peer description}\";",
      "  local as ${3:65001};",
      "  neighbor ${4:192.168.1.1} as ${5:65002};",
      "  ",
      "  multihop ${6:2};",
      "  hold time ${7:90};",
      "  ",
      "  ipv4 {",
      "    import filter ${8:import_filter};",
      "    export filter ${9:export_filter};",
      "    next hop self ${10|yes,no|};",
      "  };",
      "  $0",
      "}"
    ]
  },
  "bird-proto-bgp-rr-client": {
    "prefix": ["bird-proto-bgp-rr-client", "bgp-rr", "route-reflector"],
    "description": "[Protocol] BGP route reflector client configuration (Full)",
    "body": [
      "protocol bgp ${1:rr_client} {",
      "  local as ${2:65001};",
      "  neighbor ${3:192.168.1.1} as ${4:65001};",
      "  ",
      "  rr client;",
      "  rr cluster id ${5:192.168.1.254};",
      "  ",
      "  ipv4 {",
      "    import ${6:all};",
      "    export ${7:all};",
      "  };",
      "  $0",
      "}"
    ]
  },
  "bird-proto-bgp-confed": {
    "prefix": ["bird-proto-bgp-confed", "bgp-confederation", "confed"],
    "description": "[Protocol] BGP confederation configuration (Full)",
    "body": [
      "protocol bgp ${1:peer_name} {",
      "  local as ${2:65001};",
      "  neighbor ${3:192.168.1.1} as ${4:65002};",
      "  ",
      "  confederation ${5:64512};",
      "  confederation member ${6|yes,no|};",
      "  ",
      "  ipv4 {",
      "    import ${7:all};",
      "    export ${8:all};",
      "  };",
      "  $0",
      "}"
    ]
  },
  "bird-proto-ospf": {
    "prefix": ["bird-proto-ospf", "ospf", "protocol ospf"],
    "description": "[Protocol] OSPF routing protocol (Basic)",
    "body": [
      "protocol ospf ${1:v2} {",
      "  area ${2:0.0.0.0} {",
      "    interface \"${3:*}\" {",
      "      cost ${4:10};",
      "    };",
      "  };",
      "  $0",
      "}"
    ]
  },
  "bird-proto-ospf-area": {
    "prefix": ["bird-proto-ospf-area", "ospf-area", "area config"],
    "description": "[Protocol] OSPF area detailed configuration (Full)",
    "body": [
      "protocol ospf ${1:v2} {",
      "  area ${2:0.0.0.1} {",
      "    stub ${3|yes,no|};",
      "    ",
      "    interface \"${4:eth0}\" {",
      "      cost ${5:10};",
      "      hello ${6:10};",
      "      type ${7|broadcast,pointopoint,nbma|};",
      "    };",
      "  };",
      "  $0",
      "}"
    ]
  },
  "bird-proto-rip": {
    "prefix": ["bird-proto-rip", "rip", "protocol rip"],
    "description": "[Protocol] RIP protocol configuration (Basic)",
    "body": [
      "protocol rip ${1:rip_name} {",
      "  ipv${2|4,6|} {",
      "    import ${3:all};",
      "    export ${4:all};",
      "  };",
      "  ",
      "  interface \"${5:*}\";",
      "  $0",
      "}"
    ]
  },
  "bird-filter-simple": {
    "prefix": ["bird-filter-simple", "filter-simple", "filter"],
    "description": "[Filter] Simple accept/reject filter (Simple)",
    "body": ["filter ${1:filter_name} {", "  ${2|accept,reject|};", "  $0", "}"]
  },
  "bird-filter-block": {
    "prefix": ["bird-filter-block", "filter", "filter-block"],
    "description": "[Filter] Filter with condition block (Basic)",
    "body": [
      "filter ${1:filter_name} {",
      "  if (${2:net ~ 10.0.0.0/8}) then {",
      "    ${3|accept,reject|};",
      "  }",
      "  ",
      "  reject;",
      "  $0",
      "}"
    ]
  },
  "bird-filter-prefix": {
    "prefix": ["bird-filter-prefix", "filter-prefix", "prefix-match"],
    "description": "[Filter] Prefix list matching filter (Basic)",
    "body": [
      "filter ${1:filter_name} {",
      "  if (net ~ ${2:prefix_set}) then {",
      "    ${3|accept,reject|};",
      "  }",
      "  ",
      "  reject;",
      "  $0",
      "}"
    ]
  },
  "bird-filter-case": {
    "prefix": ["bird-filter-case", "filter-case", "case-filter"],
    "description": "[Filter] Filter with case statement (Full)",
    "body": [
      "filter ${1:filter_name} {",
      "  case ${2:bgp_community} {",
      "    (${3:65001,100}): ${4|accept,reject|};",
      "    (${5:65001,200}): ${6|accept,reject|};",
      "    else: ${7|accept,reject|};",
      "  }",
      "  $0",
      "}"
    ]
  },
  "bird-filter-community": {
    "prefix": ["bird-filter-community", "filter-comm", "community-match"],
    "description": "[Filter] BGP community matching filter (Basic)",
    "body": [
      "filter ${1:filter_name} {",
      "  if (${2:bgp_community} ~ [(${3:65001,100})]) then {",
      "    ${4|accept,reject|};",
      "  }",
      "  ",
      "  reject;",
      "  $0",
      "}"
    ]
  },
  "bird-filter-as-path": {
    "prefix": ["bird-filter-as-path", "filter-aspath", "aspath-match"],
    "description": "[Filter] AS Path regex matching filter (Full)",
    "body": [
      "filter ${1:filter_name} {",
      "  if (${2:bgp_path} ~ [${3:65001, 65002}]) then {",
      "    ${4|accept,reject|};",
      "  }",
      "  ",
      "  if (bgp_path ~ =${5:65001}=) then {",
      "    ${6|accept,reject|};",
      "  }",
      "  ",
      "  reject;",
      "  $0",
      "}"
    ]
  },
  "bird-filter-rpki": {
    "prefix": ["bird-filter-rpki", "filter-rpki", "rpki-check"],
    "description": "[Filter] RPKI validation status filter (Full)",
    "body": [
      "filter ${1:rpki_filter} {",
      "  if (roa_check(${2:roa_table}, net, bgp_path.last)) = ROA_VALID then {",
      "    ${3|accept,reject|};",
      "  }",
      "  ",
      "  if (roa_check(roa_table, net, bgp_path.last)) = ROA_INVALID then {",
      "    ${4|reject,accept|};",
      "  }",
      "  ",
      "  ${5|accept,reject|};",
      "  $0",
      "}"
    ]
  },
  "bird-filter-large-community": {
    "prefix": [
      "bird-filter-large-community",
      "filter-large-comm",
      "large-comm-match"
    ],
    "description": "[Filter] BGP Large Community matching filter (Basic)",
    "body": [
      "filter ${1:filter_name} {",
      "  if (${2:bgp_large_community} ~ [(${3:65001,100,200})]) then {",
      "    ${4|accept,reject|};",
      "  }",
      "  ",
      "  reject;",
      "  $0",
      "}"
    ]
  },
  "bird-func-basic": {
    "prefix": ["bird-func", "function", "func-def"],
    "description": "[Func] Basic function definition (Basic)",
    "body": [
      "function ${1:func_name}(${2:param}) -> ${3|int,ip,bgp_path,bool|}",
      "{",
      "  ${4:return param;}",
      "  $0",
      "}"
    ]
  },
  "bird-func-prepend": {
    "prefix": ["bird-func-prepend", "prepend", "aspath-prepend"],
    "description": "[Func] AS path prepend helper (Simple)",
    "body": [
      "function ${1:prepend_once}(bgp_path p) -> bgp_path",
      "{",
      "  return ${2:65001}, p;",
      "  $0",
      "}"
    ]
  },
  "bird-func-community": {
    "prefix": ["bird-func-community", "comm-tag", "community-set"],
    "description": "[Func] Community tagging helper (Simple)",
    "body": [
      "function ${1:set_community}() -> bgp_community",
      "{",
      "  bgp_community = bgp_community | [(${2:65001,100})];",
      "  return bgp_community;",
      "  $0",
      "}"
    ]
  },
  "bird-func-net-match": {
    "prefix": ["bird-func-net-match", "net-match", "network-match"],
    "description": "[Func] Network prefix matching helper (Basic)",
    "body": [
      "function ${1:match_prefix}(ip p) -> bool",
      "{",
      "  return net ~ [${2:10.0.0.0/8}+, ${3:192.168.0.0/16}+];",
      "  $0",
      "}"
    ]
  },
  "bird-func-metric": {
    "prefix": ["bird-func-metric", "metric-calc", "calculate-metric"],
    "description": "[Func] Dynamic metric calculation (Basic)",
    "body": [
      "function ${1:calculate_metric}() -> int",
      "{",
      "  return ${2:bgp_med} + ${3:10};",
      "  $0",
      "}"
    ]
  },
  "bird-set-prefix": {
    "prefix": ["bird-set-prefix", "bird-set", "prefix-set", "define-prefixes"],
    "description": "[Set] Prefix set definition (Basic)",
    "body": [
      "define ${1:prefix_set_name} = [",
      "  ${2:10.0.0.0/8+},",
      "  ${3:172.16.0.0/12+},",
      "  ${4:192.168.0.0/16+}",
      "];",
      "$0"
    ]
  },
  "bird-set-community": {
    "prefix": [
      "bird-set-community",
      "bird-set",
      "community-set",
      "define-communities"
    ],
    "description": "[Set] BGP community set definition (Basic)",
    "body": [
      "define ${1:community_set_name} = [",
      "  (${2:65001,100}),",
      "  (${3:65001,200}),",
      "  (${4:65002,300})",
      "];",
      "$0"
    ]
  },
  "bird-set-aspath": {
    "prefix": ["bird-set-aspath", "bird-set", "aspath-set", "define-aspath"],
    "description": "[Set] AS path set definition (Basic)",
    "body": [
      "define ${1:aspath_set_name} = [",
      "  ${2:65001},",
      "  ${3:65002},",
      "  ${4:65003}",
      "];",
      "$0"
    ]
  },
  "bird-flow-if": {
    "prefix": ["bird-flow-if", "bird-flow", "if"],
    "description": "[Control Flow] If statement template (Basic)",
    "body": [
      "if (${1:condition}) then {",
      "  ${2:action};",
      "} else {",
      "  ${3:else_action};",
      "}",
      "$0"
    ]
  },
  "bird-flow-case": {
    "prefix": ["bird-flow-case", "bird-flow", "case"],
    "description": "[Control Flow] Case statement template (Basic)",
    "body": [
      "case ${1:match_var} {",
      "  ${2:value1}: ${3:action1};",
      "  ${4:value2}: ${5:action2};",
      "  else: ${6:default_action};",
      "}",
      "$0"
    ]
  },
  "bird-flow-for": {
    "prefix": ["bird-flow-for", "bird-flow", "for", "loop"],
    "description": "[Control Flow] For loop template (Basic)",
    "body": [
      "for ${1:ip} ${2:prefix} in ${3:prefix_set} do {",
      "  ${4:action};",
      "}",
      "$0"
    ]
  }
}
