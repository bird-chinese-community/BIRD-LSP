{
  "name": "@birdcc/vscode",
  "version": "0.1.6",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "author": {
    "name": "BIRD Chinese Community",
    "email": "npm-dev@birdcc.link",
    "url": "https://github.com/bird-chinese-community/"
  },
  "displayName": "BIRD2 LSP",
  "description": "Language Server Protocol support for BIRD2 configuration files",
  "publisher": "BIRDCC",
  "repository": {
    "type": "git",
    "url": "https://github.com/bird-chinese-community/BIRD-LSP.git",
    "directory": "packages/@birdcc/vscode"
  },
  "homepage": "https://github.com/bird-chinese-community/BIRD-LSP/blob/main/packages/%40birdcc/vscode/README.md",
  "bugs": {
    "url": "https://github.com/bird-chinese-community/BIRD-LSP/issues"
  },
  "keywords": [
    "bird2",
    "routing",
    "network",
    "configuration",
    "language-server",
    "lsp",
    "vscode",
    "extension"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "icon": "assets/favicon-256.png",
  "files": [
    "dist/**",
    "data/**",
    "language-configuration.json",
    "snippets/**",
    "assets/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "main": "./dist/extension.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./extension": {
      "types": "./src/extension.ts",
      "default": "./dist/extension.js"
    }
  },
  "activationEvents": [
    "onLanguage:bird2",
    "onCommand:bird2-lsp.restartLanguageServer",
    "onCommand:bird2-lsp.enableLanguageServer",
    "onCommand:bird2-lsp.disableLanguageServer",
    "onCommand:bird2-lsp.validateActiveDocument",
    "onCommand:bird2-lsp.formatActiveDocument",
    "onCommand:bird2-lsp.openSettings",
    "onCommand:bird2-lsp.showOutputChannel",
    "onCommand:bird2-lsp.showDocumentation",
    "onCommand:bird2-lsp.reloadConfiguration",
    "workspaceContains:**/bird.conf",
    "workspaceContains:**/bird2.conf",
    "workspaceContains:**/bird3.conf",
    "workspaceContains:**/*.conf",
    "workspaceContains:**/*.bird",
    "workspaceContains:**/*.bird2",
    "workspaceContains:**/*.bird3",
    "workspaceContains:**/*.bird2.conf",
    "workspaceContains:**/*.bird3.conf"
  ],
  "contributes": {
    "languages": [
      {
        "id": "bird2",
        "aliases": [
          "BIRD2",
          "bird2"
        ],
        "extensions": [
          ".conf",
          ".bird",
          ".bird2",
          ".bird3",
          ".bird2.conf",
          ".bird3.conf"
        ],
        "filenames": [
          "bird.conf",
          "bird2.conf"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./assets/favicon.svg",
          "dark": "./assets/favicon.svg"
        }
      }
    ],
    "snippets": [
      {
        "language": "bird2",
        "path": "./snippets/bird2.json"
      }
    ],
    "commands": [
      {
        "command": "bird2-lsp.restartLanguageServer",
        "title": "BIRD2: Restart Language Server",
        "category": "BIRD2"
      },
      {
        "command": "bird2-lsp.enableLanguageServer",
        "title": "BIRD2: Enable Language Server",
        "category": "BIRD2"
      },
      {
        "command": "bird2-lsp.disableLanguageServer",
        "title": "BIRD2: Disable Language Server",
        "category": "BIRD2"
      },
      {
        "command": "bird2-lsp.validateActiveDocument",
        "title": "BIRD2: Validate Active Document",
        "category": "BIRD2"
      },
      {
        "command": "bird2-lsp.formatActiveDocument",
        "title": "BIRD2: Format Active Document",
        "category": "BIRD2"
      },
      {
        "command": "bird2-lsp.openSettings",
        "title": "BIRD2: Open Extension Settings",
        "category": "BIRD2"
      },
      {
        "command": "bird2-lsp.showOutputChannel",
        "title": "BIRD2: Show Output Channel",
        "category": "BIRD2"
      },
      {
        "command": "bird2-lsp.showDocumentation",
        "title": "BIRD2: Open Documentation",
        "category": "BIRD2"
      },
      {
        "command": "bird2-lsp.reloadConfiguration",
        "title": "BIRD2: Reload Configuration",
        "category": "BIRD2"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "!inOutput && resourceLangId == 'bird2'",
          "command": "bird2-lsp.validateActiveDocument",
          "group": "1_bird2@1"
        },
        {
          "when": "!inOutput && resourceLangId == 'bird2'",
          "command": "bird2-lsp.formatActiveDocument",
          "group": "1_bird2@2"
        }
      ],
      "commandPalette": [
        {
          "when": "resourceLangId != 'bird2'",
          "command": "bird2-lsp.validateActiveDocument",
          "visible": false
        },
        {
          "when": "resourceLangId != 'bird2'",
          "command": "bird2-lsp.formatActiveDocument",
          "visible": false
        }
      ]
    },
    "configurationDefaults": {
      "[bird2]": {
        "editor.defaultFormatter": "birdcc.bird2-lsp"
      }
    },
    "configuration": {
      "title": "BIRD2 LSP",
      "properties": {
        "bird2-lsp.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable BIRD2 language server client.",
          "scope": "resource"
        },
        "bird2-lsp.serverPath": {
          "markdownDescription": "Custom language server command override. Default behavior starts the bundled `@birdcc/lsp` server automatically.",
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ],
          "default": [
            "birdcc",
            "lsp",
            "--stdio"
          ],
          "scope": "machine-overridable"
        },
        "bird2-lsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "markdownDescription": "Trace level for language client and server communication.",
          "scope": "machine-overridable"
        },
        "bird2-lsp.hiddenErrors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "textDocument/definition",
            "textDocument/references"
          ],
          "markdownDescription": "LSP request methods to suppress from noisy failure popups.",
          "scope": "resource"
        },
        "bird2-lsp.validation.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable fallback validation with `bird -p` when needed.",
          "scope": "resource"
        },
        "bird2-lsp.validation.command": {
          "type": "string",
          "default": "bird -p -c {file}",
          "markdownDescription": "Command template for fallback validation. `{file}` will be replaced with current file path.",
          "scope": "machine-overridable"
        },
        "bird2-lsp.validation.onSave": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Run fallback validation when BIRD2 documents are saved.",
          "scope": "resource"
        },
        "bird2-lsp.validation.timeout": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "maximum": 120000,
          "markdownDescription": "Timeout for fallback validation command in milliseconds.",
          "scope": "resource"
        },
        "bird2-lsp.performance.maxFileSizeBytes": {
          "type": "number",
          "default": 2097152,
          "minimum": 65536,
          "maximum": 104857600,
          "markdownDescription": "Skip expensive extension features when file size exceeds this byte threshold.",
          "scope": "resource"
        },
        "bird2-lsp.performance.startupTimeoutMs": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "maximum": 120000,
          "markdownDescription": "Timeout for language server startup before the extension falls back to lightweight validation.",
          "scope": "resource"
        },
        "bird2-lsp.formatter.engine": {
          "type": "string",
          "enum": [
            "dprint",
            "builtin"
          ],
          "default": "dprint",
          "markdownDescription": "Preferred formatter engine for BIRD2 documents.",
          "scope": "resource"
        },
        "bird2-lsp.formatter.safeMode": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable formatter safe mode to reduce risky rewrites.",
          "scope": "resource"
        },
        "bird2-lsp.typeHints.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable Type Hints integration for BIRD2 documents.",
          "scope": "resource"
        },
        "bird2-lsp.typeHints.hover.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Show function return type details in hover tooltips.",
          "scope": "resource"
        },
        "bird2-lsp.typeHints.inlay.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Show function return type as inlay hints (POC).",
          "scope": "resource"
        }
      }
    }
  },
  "dependencies": {
    "@birdcc/lsp": "workspace:*",
    "@birdcc/parser": "workspace:*",
    "@birdcc/formatter": "workspace:*",
    "vscode-languageclient": "^9.0.1",
    "yaml": "^2.8.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/vscode": "^1.106.0",
    "@vscode/test-electron": "^2.5.2"
  },
  "scripts": {
    "sync:hover-docs": "node scripts/sync-hover-docs.mjs",
    "build": "pnpm --filter @birdcc/vscode^... build && pnpm run sync:hover-docs && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint --deny-warnings src test",
    "test": "pnpm run sync:hover-docs && pnpm --filter @birdcc/parser build && vitest run",
    "test:e2e": "pnpm --filter @birdcc/vscode... build && node e2e/run.mjs",
    "format": "oxfmt .",
    "coverage": "pnpm run sync:hover-docs && pnpm --filter @birdcc/parser build && vitest run --coverage --coverage.provider=v8 --coverage.reporter=text-summary --coverage.reporter=json-summary",
    "marketplace:package": "pnpm --filter @birdcc/vscode... build && node scripts/package-marketplace.mjs",
    "marketplace:publish:vsce": "pnpm dlx @vscode/vsce publish --packagePath ./release/bird2-lsp.vsix --pat \"$VSCE_PAT\" --pre-release",
    "marketplace:publish:ovsx": "pnpm dlx ovsx publish ./release/bird2-lsp.vsix -p \"$OVSX_PAT\""
  }
}
