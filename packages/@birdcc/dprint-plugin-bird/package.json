{
  "name": "@birdcc/dprint-plugin-bird",
  "version": "0.0.1-alpha.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/build-wasm.mjs && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint --deny-warnings src scripts && cargo fmt --all --check && cargo clippy --all-targets -- -D warnings",
    "test": "cargo test",
    "format": "oxfmt src scripts && cargo fmt --all --check"
  }
}
