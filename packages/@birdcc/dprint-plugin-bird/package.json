{
  "name": "@birdcc/dprint-plugin-bird",
  "version": "0.0.1-alpha.5",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "author": {
    "name": "BIRD Chinese Community",
    "email": "npm-dev@birdcc.link",
    "url": "https://github.com/bird-chinese-community/"
  },
  "description": "dprint plugin for formatting BIRD2 configuration files.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build-wasm.mjs && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint --deny-warnings src scripts && cargo fmt --all --check && cargo clippy --all-targets -- -D warnings",
    "test": "cargo test",
    "format": "oxfmt ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bird-chinese-community/BIRD-LSP",
    "directory": "packages/@birdcc/dprint-plugin-bird"
  },
  "homepage": "https://github.com/bird-chinese-community/BIRD-LSP/blob/main/packages/%40birdcc/dprint-plugin-bird/README.md",
  "bugs": {
    "url": "https://github.com/bird-chinese-community/BIRD-LSP/issues"
  }
}
