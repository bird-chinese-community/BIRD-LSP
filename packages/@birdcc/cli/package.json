{
  "name": "@birdcc/cli",
  "version": "0.1.0-beta.0",
  "license": "GPL-3.0-only",
  "author": {
    "name": "BIRD Chinese Community",
    "email": "npm-dev@birdcc.link",
    "url": "https://github.com/bird-chinese-community/"
  },
  "description": "CLI for linting, formatting, and language-server workflows on BIRD2 configs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "birdcc": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@birdcc/core": "0.1.0-beta.0",
    "@birdcc/formatter": "0.1.0-beta.0",
    "@birdcc/linter": "0.1.0-beta.0",
    "@birdcc/lsp": "0.1.0-beta.0",
    "cac": "^7.0.0",
    "yoctocolors": "^2.1.2",
    "zod": "^4.3.6"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint --deny-warnings src test",
    "test": "vitest run",
    "test:quick": "vitest run",
    "format": "oxfmt .",
    "coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text-summary --coverage.reporter=json-summary"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bird-chinese-community/BIRD-LSP",
    "directory": "packages/@birdcc/cli"
  },
  "homepage": "https://github.com/bird-chinese-community/BIRD-LSP/blob/main/packages/%40birdcc/cli/README.md",
  "bugs": {
    "url": "https://github.com/bird-chinese-community/BIRD-LSP/issues"
  }
}
