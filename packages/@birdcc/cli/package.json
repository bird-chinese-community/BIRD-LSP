{
  "name": "@birdcc/cli",
  "version": "0.0.1-alpha.0",
  "private": true,
  "license": "GPL-3.0-only",
  "author": {
    "name": "BIRD Chinese Community",
    "email": "npm-dev@birdcc.link",
    "url": "https://github.com/bird-chinese-community/"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "bin": {
    "birdcc": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@birdcc/core": "workspace:*",
    "@birdcc/formatter": "workspace:*",
    "@birdcc/lsp": "workspace:*",
    "@birdcc/linter": "workspace:*",
    "cac": "^6.7.14",
    "zod": "^4.1.11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint --deny-warnings src test",
    "test": "vitest run",
    "format": "oxfmt ."
  }
}
