{
  "name": "@birdcc/cli",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "bin": {
    "birdcc": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@birdcc/core": "workspace:*",
    "@birdcc/lsp": "workspace:*",
    "@birdcc/linter": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint --deny-warnings src test",
    "test": "vitest run",
    "format": "oxfmt --check src test"
  }
}
