{
  "name": "@birdcc/parser",
  "version": "0.0.1-alpha.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build:grammar": "pnpm dlx tree-sitter-cli generate && pnpm dlx tree-sitter-cli build --wasm && node scripts/sync-wasm-paths.mjs",
    "build": "tsc -p tsconfig.json && node scripts/sync-wasm-paths.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint --deny-warnings src test",
    "test": "vitest run",
    "format": "oxfmt --check src test"
  },
  "dependencies": {
    "web-tree-sitter": "^0.26.6"
  }
}
