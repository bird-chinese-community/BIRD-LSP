{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    ".agents/*",
    ".claude/*",
    "refer/*",
    "package.json",
    "node_modules/*",
    "dist/*",
    ".turbo/*",
    "target/*",
    "*.lock",
    "pnpm-*.yaml",
    "*-lock.json",
  ],
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
}