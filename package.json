{
  "name": "bird-lsp",
  "private": true,
  "license": "GPL-3.0-only",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "coverage": "turbo run coverage",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "release:publish": "pnpm build && changeset publish",
    "release:npm": "node tools/publish-npm-packages.mjs",
    "bump": "bumpp",
    "bump:alpha": "bumpp --preid alpha --release prerelease",
    "bump:patch": "bumpp --release patch",
    "bump:minor": "bumpp --release minor",
    "bump:major": "bumpp --release major",
    "sync:config-examples": "node tools/sync-config-examples.mjs",
    "sync:config-examples:check": "node tools/sync-config-examples.mjs --check",
    "sync:readme-acknowledgements": "node tools/sync-readme-acknowledgements.mjs",
    "sync:readme-acknowledgements:check": "node tools/sync-readme-acknowledgements.mjs --check"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "tree-sitter-cli"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@j178/prek": "^0.3.4",
    "@types/node": "^24.11.0",
    "@vitest/coverage-v8": "^3.2.4",
    "bumpp": "^10.4.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.51.0",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
